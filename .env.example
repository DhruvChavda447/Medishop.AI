# MediShop Pro — Environment Variables
# Copy this to .env and fill in your values

SECRET_KEY=django-insecure-change-this-in-production-use-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL Database
DB_NAME=medishop
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# Resume password — change this to something strong
RESUME_PASSWORD=MediShop@Resume2024

# Production only
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com
# DB_SSLMODE=require

# Gmail SMTP (for contact form emails)
# Step 1: Enable 2FA on your Gmail account
# Step 2: Go to Google Account > Security > App Passwords
# Step 3: Generate a 16-char app password and paste below
EMAIL_HOST_USER=your.gmail@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
CONTACT_EMAIL=dhruvchavda.intern@gmail.com
